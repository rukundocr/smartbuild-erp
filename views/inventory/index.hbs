<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Internal Inventory</h2>
        <div>
            <a href="/internal/inventory/download-pdf" id="downloadPdfBtn" class="btn btn-outline-danger me-2">
                <i class="fas fa-file-pdf me-2"></i> Download PDF
            </a>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addItemModal">
                <i class="fas fa-plus me-2"></i> Add Item
            </button>
        </div>
    </div>

    <div class="card p-4">
        <div class="row mb-3">
            <div class="col-md-3">
                <label class="form-label small text-secondary">Filter by Category</label>
                <select id="categoryFilter" class="form-select">
                    <option value="">All Categories</option>
                    <option value="Electricity">Electricity</option>
                    <option value="Water">Water</option>
                    <option value="Construction">Construction</option>
                </select>
            </div>
        </div>

        <div class="table-responsive">
            <table id="inventoryTable" class="table table-dark table-hover align-middle">
                <thead>
                    <tr>
                        <th>SKU</th>
                        <th>Item Name</th>
                        <th>Spec</th>
                        <th>Category</th>
                        <th>Description</th>
                        <th>Stock</th>
                        <th>Buying Price</th>
                        <th>Selling Price</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each items}}
                    <tr>
                        <td><code>{{this.sku}}</code></td>
                        <td>{{this.itemName}}</td>
                        <td class="small">{{this.specification}}</td>
                        <td>{{this.category}}</td>
                        <td class="small text-secondary">{{this.description}}</td>
                        <td>
                            <span
                                class="badge {{#if (gt this.minStockLevel this.quantity)}}bg-danger{{else}}bg-success{{/if}}">
                                {{this.quantity}}
                            </span>
                        </td>
                        <td>{{formatCurrency this.buyingPrice}}</td>
                        <td>{{formatCurrency this.defaultSellingPrice}}</td>
                        <td>
                            {{#if (gt this.minStockLevel this.quantity)}}
                            <span class="text-danger small"><i class="fas fa-exclamation-triangle"></i> Low Stock</span>
                            {{else}}
                            <span class="text-success small"><i class="fas fa-check-circle"></i> Healthy</span>
                            {{/if}}
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-warning me-1" title="Quick Edit"
                                onclick="toggleQuickEdit('{{this._id}}', this)">
                                <i class="fas fa-bolt"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-info me-1"
                                onclick="editItem('{{this._id}}', '{{this.itemName}}', '{{this.sku}}', '{{this.category}}', '{{this.subCategory}}', '{{this.quantity}}', '{{this.buyingPrice}}', '{{this.defaultSellingPrice}}', '{{this.minStockLevel}}', '{{this.specification}}', '{{this.description}}')">
                                <i class="fas fa-edit"></i>
                            </button>
                            <a href="/internal/inventory/delete/{{this._id}}" class="btn btn-sm btn-outline-danger"
                                onclick="return confirm('Delete this item?')">
                                <i class="fas fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add Item Modal -->
<div class="modal fade" id="addItemModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content bg-dark border-secondary">
            <form action="/internal/inventory/add" method="POST">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title">Add Inventory Item</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Item Name</label>
                        <input type="text" name="itemName" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">SKU</label>
                        <input type="text" name="sku" class="form-control" required>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Category</label>
                            <select name="category" id="modalCategory" class="form-select" required
                                onchange="updateSubCategories(this.value, 'modalSubCategory')">
                                <option value="">Select Category</option>
                                <option value="Electricity">Electricity</option>
                                <option value="Water">Water</option>
                                <option value="Construction">Construction</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Sub-Category</label>
                            <select name="subCategory" id="modalSubCategory" class="form-select" required>
                                <option value="">Select Category First</option>
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Initial Qty</label>
                            <input type="number" name="quantity" class="form-control" value="0" required>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Min Stock</label>
                            <input type="number" name="minStockLevel" class="form-control" value="5" required>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Buying Price (RWF)</label>
                            <input type="number" name="buyingPrice" class="form-control" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Selling Price (RWF)</label>
                            <input type="number" name="defaultSellingPrice" class="form-control" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Specification</label>
                        <input type="text" name="specification" class="form-control" placeholder="e.g., 10mm, Grade A">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description (Internal Use)</label>
                        <textarea name="description" class="form-control" rows="2"
                            placeholder="Internal details about the item"></textarea>
                    </div>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Item</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Item Modal -->
<div class="modal fade" id="editItemModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content bg-dark border-secondary">
            <form id="editForm" method="POST">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title">Edit Inventory Item</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="editId">
                    <div class="mb-3">
                        <label class="form-label">Item Name</label>
                        <input type="text" name="itemName" id="editName" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">SKU</label>
                        <input type="text" name="sku" id="editSku" class="form-control" required>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Category</label>
                            <select name="category" id="editCategory" class="form-select" required
                                onchange="updateSubCategories(this.value, 'editSubCategory')">
                                <option value="Electricity">Electricity</option>
                                <option value="Water">Water</option>
                                <option value="Construction">Construction</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Sub-Category</label>
                            <select name="subCategory" id="editSubCategory" class="form-select" required></select>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Quantity</label>
                            <input type="number" name="quantity" id="editQty" class="form-control" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Min Stock</label>
                            <input type="number" name="minStockLevel" id="editMin" class="form-control" required>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Buying Price</label>
                            <input type="number" name="buyingPrice" id="editBuy" class="form-control" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Selling Price</label>
                            <input type="number" name="defaultSellingPrice" id="editSell" class="form-control" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Specification</label>
                        <input type="text" name="specification" id="editSpec" class="form-control">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description (Internal Use)</label>
                        <textarea name="description" id="editDesc" class="form-control" rows="2"></textarea>
                    </div>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-info text-white">Update Item</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    const subCategories = {
        Electricity: ['Conductors', 'Protection', 'Distribution/Control', 'Terminals/Access'],
        Water: ['Pipes', 'Fittings', 'Control/Flow', 'Infrastructure/Storage'],
        Construction: ['Structural', 'Envelope/Exterior', 'Finishes/Interiors', 'Site Tools']
    };

    function updateSubCategories(category, targetId, selectedValue = '') {
        const select = document.getElementById(targetId);
        select.innerHTML = '<option value="">Select Sub-Category</option>';
        if (category && subCategories[category]) {
            subCategories[category].forEach(sub => {
                const option = document.createElement('option');
                option.value = sub;
                option.textContent = sub;
                if (sub === selectedValue) option.selected = true;
                select.appendChild(option);
            });

            // Auto-prefill SKU if adding new item
            if (targetId === 'modalSubCategory') {
                fetch(`/internal/inventory/next-sku/${category}`)
                    .then(res => res.json())
                    .then(data => {
                        if (data.nextSku) {
                            document.querySelector('#addItemModal input[name="sku"]').value = data.nextSku;
                        }
                    });
            }
        }
    }

    function editItem(id, name, sku, cat, sub, qty, buy, sell, min, spec, desc) {
        document.getElementById('editForm').action = `/internal/inventory/update/${id}`;
        document.getElementById('editName').value = name;
        document.getElementById('editSku').value = sku;
        document.getElementById('editCategory').value = cat;
        updateSubCategories(cat, 'editSubCategory', sub);
        document.getElementById('editQty').value = qty;
        document.getElementById('editBuy').value = buy;
        document.getElementById('editSell').value = sell;
        document.getElementById('editMin').value = min;
        document.getElementById('editSpec').value = spec || '';
        document.getElementById('editDesc').value = desc || '';

        new bootstrap.Modal(document.getElementById('editItemModal')).show();
    }

    function toggleQuickEdit(id, btn) {
        const row = btn.closest('tr');
        if (row.classList.contains('editing')) return;

        row.classList.add('editing');
        const cells = row.cells;

        // Store original content
        row.dataset.originalValues = JSON.stringify({
            itemName: cells[1].innerText,
            specification: cells[2].innerText,
            category: cells[3].innerText,
            description: cells[4].innerText,
            quantity: cells[5].innerText.trim(),
            buyingPrice: cells[6].innerText.replace(/[^0-9.]/g, ''),
            defaultSellingPrice: cells[7].innerText.replace(/[^0-9.]/g, '')
        });

        const data = JSON.parse(row.dataset.originalValues);

        cells[1].innerHTML = `<input type="text" class="form-control form-control-sm" value="${data.itemName}">`;
        cells[2].innerHTML = `<input type="text" class="form-control form-control-sm" value="${data.specification}">`;
        cells[3].innerHTML = `
            <select class="form-select form-select-sm">
                <option value="Electricity" ${data.category === 'Electricity' ? 'selected' : ''}>Electricity</option>
                <option value="Water" ${data.category === 'Water' ? 'selected' : ''}>Water</option>
                <option value="Construction" ${data.category === 'Construction' ? 'selected' : ''}>Construction</option>
            </select>`;
        cells[4].innerHTML = `<input type="text" class="form-control form-control-sm" value="${data.description}">`;
        cells[5].innerHTML = `<input type="number" class="form-control form-control-sm" value="${data.quantity}">`;
        cells[6].innerHTML = `<input type="number" class="form-control form-control-sm" value="${data.buyingPrice}">`;
        cells[7].innerHTML = `<input type="number" class="form-control form-control-sm" value="${data.defaultSellingPrice}">`;

        cells[9].innerHTML = `
            <button class="btn btn-sm btn-success me-1" onclick="saveQuickEdit('${id}', this)"><i class="fas fa-check"></i></button>
            <button class="btn btn-sm btn-secondary" onclick="cancelQuickEdit('${id}', this)"><i class="fas fa-times"></i></button>
        `;
    }

    function cancelQuickEdit(id, btn) {
        const row = btn.closest('tr');
        const data = JSON.parse(row.dataset.originalValues);
        const cells = row.cells;

        cells[1].innerText = data.itemName;
        cells[2].innerText = data.specification;
        cells[3].innerText = data.category;
        cells[4].innerText = data.description;
        cells[5].innerHTML = `<span class="badge bg-success">${data.quantity}</span>`; // Simplified status for revert
        cells[6].innerText = new Intl.NumberFormat('en-US').format(data.buyingPrice) + ' RWF';
        cells[7].innerText = new Intl.NumberFormat('en-US').format(data.defaultSellingPrice) + ' RWF';

        // Revert Actions
        const sku = cells[0].innerText.trim();
        // Since we don't have all data (minStock etc) easily here, we might need to refresh or store more
        // But for a professional feel, we'll reload the page if it's too complex or just restore the buttons
        location.reload();
    }

    async function saveQuickEdit(id, btn) {
        const row = btn.closest('tr');
        const cells = row.cells;
        const payload = {
            itemName: cells[1].querySelector('input').value,
            specification: cells[2].querySelector('input').value,
            category: cells[3].querySelector('select').value,
            description: cells[4].querySelector('input').value,
            quantity: cells[5].querySelector('input').value,
            buyingPrice: cells[6].querySelector('input').value,
            defaultSellingPrice: cells[7].querySelector('input').value,
            sku: cells[0].innerText.trim(), // SKU is usually required by validation
            subCategory: 'Quick Edit', // Placeholder if required
            minStockLevel: 5 // Default
        };

        try {
            const response = await fetch(`/internal/inventory/update/${id}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify(payload)
            });

            const result = await response.json();
            if (result.success) {
                location.reload(); // Refresh to ensure everything (DataTables, badges) is correct
            } else {
                alert('Error: ' + (result.message || 'Unknown error'));
            }
        } catch (err) {
            console.error(err);
            alert('Failed to save changes.');
        }
    }

    $(document).ready(function () {
        const table = $('#inventoryTable').DataTable({
            dom: 'Bfrtip',
            buttons: ['csv', 'print'],
            pageLength: 10,
            order: [[1, 'asc']]
        });

        $('#categoryFilter').on('change', function () {
            table.column(3).search(this.value).draw();

            // Update Download PDF link with the current filter
            const baseUrl = '/internal/inventory/download-pdf';
            const category = this.value;
            const newUrl = category ? `${baseUrl}?category=${encodeURIComponent(category)}` : baseUrl;
            $('#downloadPdfBtn').attr('href', newUrl);
        });
    });
</script>