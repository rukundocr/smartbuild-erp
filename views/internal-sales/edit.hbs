<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Edit Internal Invoice</h2>
        <a href="/internal/sales/summary" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i> Back to Summary
        </a>
    </div>

    <form id="invoiceForm" action="/internal/sales/edit/{{invoice._id}}" method="POST">
        <div class="row">
            <div class="col-lg-8">
                <div class="card p-4 mb-4">
                    <h5 class="fw-bold mb-3 border-bottom border-secondary pb-2">Invoice Details</h5>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Client</label>
                            <select name="clientId" class="form-select" required>
                                {{#each clients}}
                                <option value="{{this._id}}" {{#if (eq (toString this._id) (toString
                                    ../invoice.clientId))}}selected{{/if}}>
                                    {{this.clientName}}
                                </option>
                                {{/each}}
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Invoice Number</label>
                            <input type="text" name="invoiceNo" class="form-control" value="{{invoice.invoiceNo}}"
                                required readonly>
                        </div>
                    </div>

                    <h5 class="fw-bold mt-4 mb-3 border-bottom border-secondary pb-2">Items</h5>
                    <div id="itemsContainer">
                        {{#each invoice.items}}
                        <div class="item-row row mb-3 align-items-end" id="row{{@index}}">
                            <div class="col-md-5">
                                <label class="form-label small">Select Item</label>
                                <select name="items[{{@index}}][itemId]" class="form-select item-select" required
                                    onchange="updateRowData({{@index}}, this.value)">
                                    <option value="">Choose item...</option>
                                    {{#each ../items}}
                                    <option value="{{this._id}}" data-price="{{this.defaultSellingPrice}}"
                                        data-cost="{{this.buyingPrice}}" data-stock="{{this.quantity}}"
                                        data-spec="{{this.specification}}" {{#if (eq (toString this._id) (toString
                                        ../itemId._id))}}selected{{/if}} {{#if (lte this.quantity 0)}}disabled{{/if}}>
                                        {{this.itemName}} {{#if this.specification}}- {{this.specification}}{{/if}}
                                        (Stock: {{this.quantity}}){{#if (lte this.quantity 0)}} - OUT
                                        OF STOCK{{/if}}
                                    </option>
                                    {{/each}}
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small">Qty</label>
                                <input type="number" name="items[{{@index}}][qty]" class="form-control qty-input"
                                    value="{{this.qty}}" min="1" required onchange="calculateRow({{@index}})">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small">Price (RWF)</label>
                                <input type="number" name="items[{{@index}}][priceAtSale]"
                                    class="form-control price-input" value="{{this.priceAtSale}}" required
                                    onchange="calculateRow({{@index}})">
                                <input type="hidden" name="items[{{@index}}][costAtSale]" class="cost-input"
                                    value="{{this.costAtSale}}">
                            </div>
                            <div class="col-md-2">
                                <button type="button" class="btn btn-outline-danger w-100"
                                    onclick="removeRow({{@index}})" {{#if (eq @index 0)}}disabled{{/if}}>
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                        {{/each}}
                    </div>
                    <button type="button" class="btn btn-outline-info btn-sm mt-2" onclick="addRow()">
                        <i class="fas fa-plus me-1"></i> Add Another Item
                    </button>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card p-4 sticky-top" style="top: 100px;">
                    <h5 class="fw-bold mb-3 border-bottom border-secondary pb-2">Summary</h5>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Items Count:</span>
                        <span id="itemsCount">{{invoice.items.length}}</span>
                    </div>
                    <div class="d-flex justify-content-between mb-4 mt-2">
                        <h4 class="fw-bold">Total:</h4>
                        <h4 class="fw-bold text-primary" id="displayTotal">{{formatCurrency invoice.grandTotal}}</h4>
                        <input type="hidden" name="grandTotal" id="grandTotal" value="{{invoice.grandTotal}}">
                    </div>
                    <button type="submit" class="btn btn-info w-100 btn-lg shadow text-white">
                        <i class="fas fa-save me-2"></i> Update Invoice
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

<script>
    let rowCount = {{ invoice.items.length }};

    // Initialize Select2
    function initSelect2(selector) {
        $(selector).select2({
            theme: 'bootstrap-5',
            placeholder: 'Choose item...',
            width: '100%'
        });
    }

    $(document).ready(function () {
        initSelect2('.item-select');
    });

    function addRow() {
        const container = document.getElementById('itemsContainer');
        const newRow = document.createElement('div');
        newRow.className = 'item-row row mb-3 align-items-end';
        newRow.id = `row${rowCount}`;
        newRow.innerHTML = `
        <div class="col-md-5">
            <select name="items[${rowCount}][itemId]" class="form-select item-select" required onchange="updateRowData(${rowCount}, this.value)">
                <option value="">Choose item...</option>
                {{#each items}}
                <option value="{{this._id}}" data-price="{{this.defaultSellingPrice}}" data-cost="{{this.buyingPrice}}" data-stock="{{this.quantity}}" data-spec="{{this.specification}}" {{#if (lte this.quantity 0)}}disabled{{/if}}>
                    {{this.itemName}} {{#if this.specification}}- {{this.specification}}{{/if}} (Stock: {{this.quantity}}){{#if (lte this.quantity 0)}} - OUT OF STOCK{{/if}}
                </option>
                {{/each}}
            </select>
        </div>
        <div class="col-md-2">
            <input type="number" name="items[${rowCount}][qty]" class="form-control qty-input" value="1" min="1" required onchange="calculateRow(${rowCount})">
        </div>
        <div class="col-md-3">
            <input type="number" name="items[${rowCount}][priceAtSale]" class="form-control price-input" required onchange="calculateRow(${rowCount})">
            <input type="hidden" name="items[${rowCount}][costAtSale]" class="cost-input">
        </div>
        <div class="col-md-2">
            <button type="button" class="btn btn-outline-danger w-100" onclick="removeRow(${rowCount})">
                <i class="fas fa-trash"></i>
            </button>
        </div>
    `;
        container.appendChild(newRow);

        // Initialize Select2 for the new row
        initSelect2(`#row${rowCount} .item-select`);

        rowCount++;
        updateCounts();
    }

    function removeRow(id) {
        document.getElementById(`row${id}`).remove();
        updateCounts();
    }

    function updateRowData(id, val) {
        const row = document.getElementById(`row${id}`);
        const select = row.querySelector('.item-select');
        const selectedOption = select.options[select.selectedIndex];

        // CHECK IF ITEM IS ALREADY SELECTED IN ANOTHER ROW
        const allSelects = document.querySelectorAll('.item-select');
        let duplicate = false;
        allSelects.forEach(s => {
            if (s !== select && s.value === val && val !== "") {
                duplicate = true;
            }
        });

        if (duplicate) {
            alert("This item is already added to the invoice. Please adjust the quantity in the existing row instead.");
            select.value = "";
            row.querySelector('.price-input').value = '';
            row.querySelector('.cost-input').value = '';
            row.querySelector('.qty-input').removeAttribute('max');
            calculateTotal();
            return;
        }

        if (val) {
            row.querySelector('.price-input').value = selectedOption.dataset.price || '';
            row.querySelector('.cost-input').value = selectedOption.dataset.cost || '';
            row.querySelector('.qty-input').max = selectedOption.dataset.stock || '';

            // If current quantity is higher than stock, reset it (Caution in Edit mode)
            const qtyInput = row.querySelector('.qty-input');
            const stock = parseInt(selectedOption.dataset.stock) || 0;
            // Note: In Edit mode, the "actual" stock available is (current stock + original invoice qty)
            // But for now we stick to the basic guard to prevent negative stock at the source.
            if (parseInt(qtyInput.value) > stock) {
                // We only auto-reset if it's a new item being selected. 
                // If it's the original item, we might need more logic, but user wants "No Negative Stock".
                // qtyInput.value = stock; 
            }
        } else {
            row.querySelector('.price-input').value = '';
            row.querySelector('.cost-input').value = '';
            row.querySelector('.qty-input').removeAttribute('max');
        }
        calculateTotal();
    }

    function calculateRow(id) {
        calculateTotal();
    }

    function calculateTotal() {
        let total = 0;
        document.querySelectorAll('.item-row').forEach(row => {
            const qty = parseFloat(row.querySelector('.qty-input').value) || 0;
            const price = parseFloat(row.querySelector('.price-input').value) || 0;
            total += (qty * price);
        });

        document.getElementById('grandTotal').value = total;
        document.getElementById('displayTotal').innerText = new Intl.NumberFormat('en-US').format(total) + ' RWF';
    }

    function updateCounts() {
        document.getElementById('itemsCount').innerText = document.querySelectorAll('.item-row').length;
        calculateTotal();
    }

    // FORM SUBMISSION GUARD
    document.getElementById('invoiceForm').addEventListener('submit', function (e) {
        const rows = document.querySelectorAll('.item-row');
        const itemIds = new Set();
        let valid = true;

        rows.forEach(row => {
            const select = row.querySelector('.item-select');
            const qtyInput = row.querySelector('.qty-input');
            const itemId = select.value;
            const qty = parseInt(qtyInput.value) || 0;
            const stock = parseInt(select.options[select.selectedIndex].dataset.stock) || 0;

            if (!itemId) {
                alert("Please select an item for all rows.");
                valid = false;
                return;
            }

            if (itemIds.has(itemId)) {
                alert("Duplicate items found. Each item can only be added once.");
                valid = false;
                return;
            }
            itemIds.add(itemId);

            // In Edit mode, the check is more complex on the backend. 
            // We let the backend handle the full stock verification for edits 
            // while preventing obvious duplicates on frontend.

            if (qty <= 0) {
                alert("Quantity must be greater than zero.");
                valid = false;
                return;
            }
        });

        if (!valid) {
            e.preventDefault();
        }
    });
</script>