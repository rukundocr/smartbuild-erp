<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: #fff;
            color: #000;
            font-family: 'Courier New', Courier, monospace;
        }

        .receipt-container {
            max-width: 400px;
            margin: 20px auto;
            border: 1px dashed #ccc;
            padding: 20px;
        }

        .header {
            text-align: center;
            border-bottom: 2px solid #000;
            padding-bottom: 10px;
            margin-bottom: 15px;
        }

        .item-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 5px;
            font-size: 0.9rem;
        }

        .total-row {
            border-top: 1px double #000;
            margin-top: 15px;
            padding-top: 10px;
            font-weight: bold;
            font-size: 1.1rem;
        }

        .footer {
            text-align: center;
            margin-top: 30px;
            font-size: 0.8rem;
            border-top: 1px solid #eee;
            padding-top: 10px;
        }

        @media print {
            .no-print {
                display: none;
            }

            .receipt-container {
                border: none;
                margin: 0;
                padding: 0;
            }
        }
    </style>
</head>

<body>
    <div class="no-print mt-3 text-center mb-3">
        <a href="/internal/sales/download-pdf/{{invoice._id}}?format=a4" class="btn btn-primary me-2" target="_blank">
            <i class="fas fa-file-pdf"></i> Print A4
        </a>
        <a href="/internal/sales/download-pdf/{{invoice._id}}?format=thermal" class="btn btn-dark me-2" target="_blank">
            <i class="fas fa-receipt"></i> Print Thermal (80mm)
        </a>
        <button class="btn btn-outline-primary me-2" onclick="window.print()">
            <i class="fas fa-print"></i> Native Print
        </button>
        <a href="/internal/sales/summary" class="btn btn-outline-secondary">Back to Sales</a>
    </div>

    <div class="receipt-container">
        <div class="header">
            <h3>SMARTBUILD ERP</h3>
            <p class="mb-0">Internal Project Supplies</p>
            <p class="small">Date: {{formatDate invoice.date}}</p>
        </div>

        <div class="mb-3">
            <strong>Invoice:</strong> {{invoice.invoiceNo}}<br>
            <strong>Status:</strong> <span class="text-uppercase fw-bold">{{invoice.status}}</span><br>
            <strong>Client:</strong> {{invoice.clientId.clientName}}<br>
            <strong>Phone:</strong> {{invoice.clientId.phone}}
        </div>

        <div class="border-bottom mb-2 pb-1">
            <strong>ITEMS:</strong>
        </div>

        {{#each invoice.items}}
        <div class="mb-2">
            <div>{{this.itemId.itemName}} {{#if this.itemId.specification}}- {{this.itemId.specification}}{{/if}}</div>
            <div class="item-row">
                <span>{{this.qty}} x {{this.priceAtSale}}</span>
                <span>{{formatCurrency (add 0 (multiply this.qty this.priceAtSale))}}</span>
            </div>
        </div>
        {{/each}}

        <div class="total-row item-row">
            <span>GRAND TOTAL</span>
            <span>{{formatCurrency invoice.grandTotal}}</span>
        </div>

        <div class="footer">
            <p>Thank you for your business!</p>
            <p>*** Internal Receipt ***</p>
        </div>
    </div>

    <script>
        // Simple mock of multiply if needed since it's common
        // But better to define it in helpers if not already there
    </script>
</body>

</html>